# Database Configuration
DATABASE_URL=mysql+pymysql://ledger_user:ledger_pass@db:3306/ledger_db

# Security - CRITICAL: Change these in production!
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_THIS_TO_RANDOM_64_CHARACTER_HEX_STRING_GENERATED_WITH_OPENSSL
ALGORITHM=HS256

# JWT Configuration
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration
# Comma-separated list of allowed origins
# For production, list specific domains only
ALLOWED_ORIGINS=http://localhost,http://localhost:80

# Rate Limiting
# Login attempts before lockout
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=5

# Registration rate limit
MAX_REGISTRATIONS_PER_HOUR=3

# Password Policy
MIN_PASSWORD_LENGTH=8
MAX_PASSWORD_LENGTH=128
REQUIRE_PASSWORD_COMPLEXITY=true

# Session Security
SESSION_TIMEOUT_MINUTES=30
ENABLE_SESSION_REFRESH=true

# Logging
LOG_LEVEL=INFO
ENABLE_AUDIT_LOGGING=true
LOG_FILE_PATH=/var/log/ledger/app.log

# Security Headers
ENABLE_HSTS=false  # Set to true only if using HTTPS
HSTS_MAX_AGE=31536000

# Content Security Policy
ENABLE_CSP=true
CSP_REPORT_URI=/api/csp-report

# File Upload (if implemented)
MAX_UPLOAD_SIZE_MB=10
ALLOWED_FILE_EXTENSIONS=pdf,png,jpg,jpeg,csv,xlsx

# Database Security
DB_CONNECTION_TIMEOUT=30
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# API Security
ENABLE_API_KEY_AUTH=false
API_RATE_LIMIT_PER_MINUTE=60

# Monitoring and Alerts
ENABLE_SECURITY_MONITORING=true
ALERT_ON_FAILED_LOGINS=5
ALERT_EMAIL=security@your-domain.com

# Environment
ENVIRONMENT=development  # development, staging, production

# PQC Configuration (Future)
# When NIST finalizes PQC standards:
# PQC_ENABLED=false
# PQC_ALGORITHM=CRYSTALS-Dilithium
# PQC_KEY_EXCHANGE=CRYSTALS-KYBER

# Backup Configuration
ENABLE_AUTO_BACKUP=true
BACKUP_RETENTION_DAYS=30

# Feature Flags
ENABLE_2FA=false  # Two-factor authentication (future)
ENABLE_EMAIL_VERIFICATION=false  # Email verification (future)
ENABLE_PASSWORD_RESET=false  # Password reset via email (future)
